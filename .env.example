# Postgres connection string for the shared monorepo RDS instance.
# Auto-written by `npm run provision` from AWS Secrets Manager.
DATABASE_URL_MONOREPO=

# Auth token for the backend's /admin/refresh-schemas endpoint.
# Auto-written by `npm run provision` from AWS Secrets Manager.
ADMIN_SECRET=

# Optional: override the backend URL for `npm run db:push`.
# Default: https://api.digo-labs.com
# Set this if you're running the backend locally and want db:push to refresh your local instance.
# BACKEND_URL=http://localhost:3000